# Copy to .env.local and fill in values from the Firebase console.
# The app runs without these variables using local mock content in src/lib/siteContent.ts.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional — not required for auth, Firestore, or Storage
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Optional — comma-separated admin emails. If unset, any authenticated Firebase user can access admin.
# NEXT_PUBLIC_ADMIN_EMAIL_ALLOWLIST=admin@example.com,owner@example.com

# Quote email notifications (server-only — do not prefix with NEXT_PUBLIC_)
# RESEND_API_KEY=
# QUOTE_NOTIFICATION_EMAIL=you@example.com
# QUOTE_FROM_EMAIL=XMBroider <notifications@your-verified-domain.com>
# SEND_CUSTOMER_QUOTE_CONFIRMATION=true

# Optional — Firebase Admin service account JSON (single line) to persist notificationStatus on quotes
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
